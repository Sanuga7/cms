generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id     Int     @id @default(autoincrement())
  role   String  @db.VarChar(45)
  admins Admin[]
}

model Status {
  id           Int           @id @default(autoincrement())
  status       String        @db.VarChar(45)
  admins       Admin[]
  news         News[]
  achievements Achievement[]
  sports       Sport[]
  societies    Society[]
  events       Event[]
}

model Admin {
  username     String        @id @db.VarChar(10)
  fname        String        @db.VarChar(45)
  lname        String        @db.VarChar(45)
  lastLogin    DateTime      @map("last_login")
  password     String        @db.VarChar(255) // Increased for hashed passwords
  roleId       Int           @map("role_id")
  statusId     Int           @map("status_id")
  
  role         Role          @relation(fields: [roleId], references: [id])
  status       Status        @relation(fields: [statusId], references: [id])
  
  news         News[]
  achievements Achievement[]
  sports       Sport[]
  societies    Society[]
  events       Event[]
}

model Image {
  id           Int           @id @default(autoincrement())
  path         String        @db.Text
  news         News[]
  achievements Achievement[]
  sports       Sport[]
  societies    Society[]
  events       Event[]
}

model News {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(45)
  description String   @db.Text
  addedTime   DateTime @default(now()) @map("added_time")
  addedUser   String   @db.VarChar(10) @map("added_user")
  imageId     Int      @map("images_id")
  statusId    Int      @map("status_id")

  admin       Admin    @relation(fields: [addedUser], references: [username])
  image       Image    @relation(fields: [imageId], references: [id])
  status      Status   @relation(fields: [statusId], references: [id])
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(45)
  description String   @db.Text
  addedTime   DateTime @default(now()) @map("added_time")
  statusId    Int      @map("status_id")
  imageId     Int      @map("images_id")
  addedUser   String   @db.VarChar(10) @map("added_user")

  status      Status   @relation(fields: [statusId], references: [id])
  image       Image    @relation(fields: [imageId], references: [id])
  admin       Admin    @relation(fields: [addedUser], references: [username])
}

model Sport {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(45)
  description String   @db.VarChar(45)
  addedTime   DateTime @default(now()) @map("added_time")
  imageId     Int      @map("images_id")
  statusId    Int      @map("status_id")
  addedUser   String   @db.VarChar(10) @map("added_user")

  image       Image    @relation(fields: [imageId], references: [id])
  status      Status   @relation(fields: [statusId], references: [id])
  admin       Admin    @relation(fields: [addedUser], references: [username])

  @@map("sports")
}

model Society {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(45)
  description String   @db.VarChar(45)
  addedTime   DateTime @default(now()) @map("added_time")
  imageId     Int      @map("images_id")
  statusId    Int      @map("status_id")
  addedUser   String   @db.VarChar(10) @map("added_user")

  image       Image    @relation(fields: [imageId], references: [id])
  status      Status   @relation(fields: [statusId], references: [id])
  admin       Admin    @relation(fields: [addedUser], references: [username])

  @@map("socities")
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(45)
  description String   @db.VarChar(45) @map("decription")
  addedTime   DateTime @default(now()) @map("added_time")
  eventDate   DateTime @map("event_date")
  location    String   @db.Text
  statusId    Int      @map("status_id")
  imageId     Int      @map("images_id")
  addedUser   String   @db.VarChar(10) @map("added_user")

  status      Status   @relation(fields: [statusId], references: [id])
  image       Image    @relation(fields: [imageId], references: [id])
  admin       Admin    @relation(fields: [addedUser], references: [username])
}

model MiscResource {
  id   Int    @id @default(autoincrement())
  path String @db.Text

  @@map("misc_resources")
}